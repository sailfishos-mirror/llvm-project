; CHECK-NEXT:    [[TMP9:%.*]] = fcmp fast olt <4 x float> [[REVERSE]], [[VEC_PHI]]
; CHECK-NEXT:    [[TMP10]] = select <4 x i1> [[TMP9]], <4 x i64> [[VEC_IND]], <4 x i64> [[VEC_PHI1]]
