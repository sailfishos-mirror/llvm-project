; Multi-use case: inner shuffles used elsewhere, should still optimize
; The unused inner1 shuffles will be DCE'd since they're no longer used after optimization
define <4 x i8> @multi_use(<4 x i8> %x_then, <4 x i8> %y_then, <4 x i8> %x_else, <4 x i8> %y_else, i1 %cond, ptr %out) {
; CHECK-LABEL: @multi_use(
; CHECK-NEXT:  entry:
; CHECK-NEXT:    br i1 [[COND:%.*]], label [[THEN:%.*]], label [[ELSE:%.*]]
; CHECK:       then:
; CHECK-NEXT:    [[INNER0_THEN:%.*]] = shufflevector <4 x i8> [[X_THEN:%.*]], <4 x i8> [[Y_THEN:%.*]], <4 x i32> <i32 0, i32 1, i32 4, i32 5>
; CHECK-NEXT:    br label [[MERGE:%.*]]
; CHECK:       else:
; CHECK-NEXT:    [[INNER0_ELSE:%.*]] = shufflevector <4 x i8> [[X_ELSE:%.*]], <4 x i8> [[Y_ELSE:%.*]], <4 x i32> <i32 0, i32 1, i32 4, i32 5>
; CHECK-NEXT:    br label [[MERGE]]
; CHECK:       merge:
; CHECK-NEXT:    [[SHUFFLE_PHI_OPT:%.*]] = phi <4 x i8> [ [[X_THEN]], [[THEN]] ], [ [[X_ELSE]], [[ELSE]] ]
; CHECK-NEXT:    [[PHI0:%.*]] = phi <4 x i8> [ [[INNER0_THEN]], [[THEN]] ], [ [[INNER0_ELSE]], [[ELSE]] ]
; CHECK-NEXT:    store <4 x i8> [[PHI0]], ptr [[OUT:%.*]], align 4
; CHECK-NEXT:    ret <4 x i8> [[SHUFFLE_PHI_OPT]]
;
entry:
  br i1 %cond, label %then, label %else

then:
  %inner0_then = shufflevector <4 x i8> %x_then, <4 x i8> %y_then, <4 x i32> <i32 0, i32 1, i32 4, i32 5>
  %inner1_then = shufflevector <4 x i8> %x_then, <4 x i8> %y_then, <4 x i32> <i32 2, i32 3, i32 6, i32 7>
  br label %merge

else:
  %inner0_else = shufflevector <4 x i8> %x_else, <4 x i8> %y_else, <4 x i32> <i32 0, i32 1, i32 4, i32 5>
  %inner1_else = shufflevector <4 x i8> %x_else, <4 x i8> %y_else, <4 x i32> <i32 2, i32 3, i32 6, i32 7>
  br label %merge

merge:
  %phi0 = phi <4 x i8> [ %inner0_then, %then ], [ %inner0_else, %else ]
  %phi1 = phi <4 x i8> [ %inner1_then, %then ], [ %inner1_else, %else ]
  ; phi0 is also used here
  store <4 x i8> %phi0, ptr %out
  %result = shufflevector <4 x i8> %phi0, <4 x i8> %phi1, <4 x i32> <i32 0, i32 1, i32 4, i32 5>
  ret <4 x i8> %result
}
