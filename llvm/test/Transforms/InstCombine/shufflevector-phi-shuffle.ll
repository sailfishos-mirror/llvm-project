; Loop case: inner shuffles in loop backedge
define <4 x i8> @loop_backedge(<4 x i8> %x_init, <4 x i8> %y_init, <4 x i8> %x_update, <4 x i8> %y_update, i1 %cond) {
; CHECK-LABEL: @loop_backedge(
; CHECK-NEXT:  entry:
; CHECK-NEXT:    br label [[LOOP:%.*]]
; CHECK:       loop:
; CHECK-NEXT:    [[SHUFFLE_PHI_OPT:%.*]] = phi <4 x i8> [ [[X_INIT:%.*]], [[ENTRY:%.*]] ], [ [[X_UPDATE:%.*]], [[LOOP]] ]
; CHECK-NEXT:    br i1 [[COND:%.*]], label [[LOOP]], label [[EXIT:%.*]]
; CHECK:       exit:
; CHECK-NEXT:    ret <4 x i8> [[SHUFFLE_PHI_OPT]]
;
entry:
  %inner0_init = shufflevector <4 x i8> %x_init, <4 x i8> %y_init, <4 x i32> <i32 0, i32 1, i32 4, i32 5>
  %inner1_init = shufflevector <4 x i8> %x_init, <4 x i8> %y_init, <4 x i32> <i32 2, i32 3, i32 6, i32 7>
  br label %loop

loop:
  %phi0 = phi <4 x i8> [ %inner0_init, %entry ], [ %inner0_update, %loop ]
  %phi1 = phi <4 x i8> [ %inner1_init, %entry ], [ %inner1_update, %loop ]
  %result = shufflevector <4 x i8> %phi0, <4 x i8> %phi1, <4 x i32> <i32 0, i32 1, i32 4, i32 5>
  %inner0_update = shufflevector <4 x i8> %x_update, <4 x i8> %y_update, <4 x i32> <i32 0, i32 1, i32 4, i32 5>
  %inner1_update = shufflevector <4 x i8> %x_update, <4 x i8> %y_update, <4 x i32> <i32 2, i32 3, i32 6, i32 7>
  br i1 %cond, label %loop, label %exit

exit:
  ret <4 x i8> %result
}

