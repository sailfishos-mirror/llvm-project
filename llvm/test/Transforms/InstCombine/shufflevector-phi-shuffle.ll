; Test folding of shuffle(phi(shuffle, ...), phi(shuffle, ...)) patterns
; where the inner shuffles have the same masks and the composition is identity.

; Identity on src0 (X): outer shuffle recovers X from interleaved shuffles
define <4 x i8> @identity_src0(<4 x i8> %x_then, <4 x i8> %y_then, <4 x i8> %x_else, <4 x i8> %y_else, i1 %cond) {
; CHECK-LABEL: @identity_src0(
; CHECK-NEXT:  entry:
; CHECK-NEXT:    br i1 [[COND:%.*]], label [[THEN:%.*]], label [[ELSE:%.*]]
; CHECK:       then:
; CHECK-NEXT:    br label [[MERGE:%.*]]
; CHECK:       else:
; CHECK-NEXT:    br label [[MERGE]]
; CHECK:       merge:
; CHECK-NEXT:    [[SHUFFLE_PHI_OPT:%.*]] = phi <4 x i8> [ [[X_THEN:%.*]], [[THEN]] ], [ [[X_ELSE:%.*]], [[ELSE]] ]
; CHECK-NEXT:    ret <4 x i8> [[SHUFFLE_PHI_OPT]]
;
entry:
  br i1 %cond, label %then, label %else

then:
  ; Interleave low bytes: X[0], Y[0], X[1], Y[1]
  %inner0_then = shufflevector <4 x i8> %x_then, <4 x i8> %y_then, <4 x i32> <i32 0, i32 4, i32 1, i32 5>
  ; Interleave high bytes: X[2], Y[2], X[3], Y[3]
  %inner1_then = shufflevector <4 x i8> %x_then, <4 x i8> %y_then, <4 x i32> <i32 2, i32 6, i32 3, i32 7>
  br label %merge

else:
  %inner0_else = shufflevector <4 x i8> %x_else, <4 x i8> %y_else, <4 x i32> <i32 0, i32 4, i32 1, i32 5>
  %inner1_else = shufflevector <4 x i8> %x_else, <4 x i8> %y_else, <4 x i32> <i32 2, i32 6, i32 3, i32 7>
  br label %merge

merge:
  %phi0 = phi <4 x i8> [ %inner0_then, %then ], [ %inner0_else, %else ]
  %phi1 = phi <4 x i8> [ %inner1_then, %then ], [ %inner1_else, %else ]
  ; De-interleave to recover X: inner0[0], inner0[2], inner1[0], inner1[2]
  ;                            = X[0], X[1], X[2], X[3]
  %result = shufflevector <4 x i8> %phi0, <4 x i8> %phi1, <4 x i32> <i32 0, i32 2, i32 4, i32 6>
  ret <4 x i8> %result
}

