# NOTE: Assertions have been autogenerated by utils/update_mir_test_checks.py
# RUN: llc -mtriple=powerpc64le-unknown-linux-gnu -mcpu=pwr9 -run-pass=ppc-mi-peepholes -ppc-eliminate-signext -verify-machineinstrs -o - %s | FileCheck %s

# When the EXTSW_32_64 input reads the sub_32 subregister of a 64-bit register
# that is already sign-extended (here RLDICL with MB >= 33), the high 32 bits of
# that register already hold the sign extension of the low word, so the result
# of the sign-extend is the whole 64-bit register. Eliminate the EXTSW by
# copying that register directly rather than building an INSERT_SUBREG that would
# use the full register where a 32-bit register is required.

---
name:            extsw_elim_subreg_input
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $x3
    ; CHECK-LABEL: name: extsw_elim_subreg_input
    ; CHECK: liveins: $x3
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:g8rc = COPY killed $x3
    ; CHECK-NEXT: [[RLDICL:%[0-9]+]]:g8rc = RLDICL killed [[COPY]], 0, 33
    ; CHECK-NEXT: [[COPY1:%[0-9]+]]:g8rc = COPY killed [[RLDICL]]
    ; CHECK-NEXT: $x3 = COPY killed [[COPY1]]
    ; CHECK-NEXT: BLR8 implicit $lr8, implicit $rm, implicit killed $x3
    %0:g8rc = COPY $x3
    %1:g8rc = RLDICL %0, 0, 33
    %2:g8rc = EXTSW_32_64 %1.sub_32
    $x3 = COPY %2
    BLR8 implicit $lr8, implicit $rm, implicit $x3
...
