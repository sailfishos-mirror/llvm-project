# NOTE: Assertions have been autogenerated by utils/update_mir_test_checks.py
# RUN: llc -mtriple=powerpc64le-unknown-linux-gnu -mcpu=pwr9 -run-pass=ppc-mi-peepholes -ppc-eliminate-signext -verify-machineinstrs -o - %s | FileCheck %s

# EXTSW_32_64 reading the sub_32 of an already-sign-extended 64-bit register
# (here RLDICL with MB >= 33) is redundant, so it is replaced by a copy of the
# full register.

---
name:            extsw_elim_subreg_input
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $x3
    ; CHECK-LABEL: name: extsw_elim_subreg_input
    ; CHECK: liveins: $x3
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:g8rc = COPY killed $x3
    ; CHECK-NEXT: [[RLDICL:%[0-9]+]]:g8rc = RLDICL killed [[COPY]], 0, 33
    ; CHECK-NEXT: [[COPY1:%[0-9]+]]:g8rc = COPY killed [[RLDICL]]
    ; CHECK-NEXT: $x3 = COPY killed [[COPY1]]
    ; CHECK-NEXT: BLR8 implicit $lr8, implicit $rm, implicit killed $x3
    %0:g8rc = COPY $x3
    %1:g8rc = RLDICL %0, 0, 33
    %2:g8rc = EXTSW_32_64 %1.sub_32
    $x3 = COPY %2
    BLR8 implicit $lr8, implicit $rm, implicit $x3
...

# A 64-bit zero-extending word load (LWZ8/LWZX8) feeding an EXTSW that reads its
# sub_32 is folded into a sign-extending load, the same way a gprc LWZ/LWZX +
# EXTSW folds.
---
name:            extsw_lwz8_subreg_input
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $x3
    ; CHECK-LABEL: name: extsw_lwz8_subreg_input
    ; CHECK: liveins: $x3
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:g8rc_and_g8rc_nox0 = COPY killed $x3
    ; CHECK-NEXT: [[LWA:%[0-9]+]]:g8rc = LWA 0, killed [[COPY]] :: (load (s32))
    ; CHECK-NEXT: dead [[DEF:%[0-9]+]]:g8rc = IMPLICIT_DEF
    ; CHECK-NEXT: $x3 = COPY killed [[LWA]]
    ; CHECK-NEXT: BLR8 implicit $lr8, implicit $rm, implicit killed $x3
    %0:g8rc_and_g8rc_nox0 = COPY $x3
    %1:g8rc = LWZ8 0, %0 :: (load (s32))
    %2:g8rc = EXTSW_32_64 %1.sub_32
    $x3 = COPY %2
    BLR8 implicit $lr8, implicit $rm, implicit $x3
...

# Indexed load (X-form, no alignment requirement).
---
name:            extsw_lwzx8_subreg_input
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $x3, $x4
    ; CHECK-LABEL: name: extsw_lwzx8_subreg_input
    ; CHECK: liveins: $x3, $x4
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:g8rc_and_g8rc_nox0 = COPY killed $x3
    ; CHECK-NEXT: [[COPY1:%[0-9]+]]:g8rc = COPY killed $x4
    ; CHECK-NEXT: [[LWAX:%[0-9]+]]:g8rc = LWAX killed [[COPY]], killed [[COPY1]] :: (load (s32))
    ; CHECK-NEXT: dead [[DEF:%[0-9]+]]:g8rc = IMPLICIT_DEF
    ; CHECK-NEXT: $x3 = COPY killed [[LWAX]]
    ; CHECK-NEXT: BLR8 implicit $lr8, implicit $rm, implicit killed $x3
    %0:g8rc_and_g8rc_nox0 = COPY $x3
    %3:g8rc = COPY $x4
    %1:g8rc = LWZX8 %0, %3 :: (load (s32))
    %2:g8rc = EXTSW_32_64 %1.sub_32
    $x3 = COPY %2
    BLR8 implicit $lr8, implicit $rm, implicit $x3
...

# 32-bit result EXTSW_32.
---
name:            extsw32_lwz8_subreg_input
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $x3
    ; CHECK-LABEL: name: extsw32_lwz8_subreg_input
    ; CHECK: liveins: $x3
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:g8rc_and_g8rc_nox0 = COPY killed $x3
    ; CHECK-NEXT: [[LWA_32_:%[0-9]+]]:gprc = LWA_32 0, killed [[COPY]] :: (load (s32))
    ; CHECK-NEXT: dead [[DEF:%[0-9]+]]:g8rc = IMPLICIT_DEF
    ; CHECK-NEXT: [[DEF1:%[0-9]+]]:g8rc = IMPLICIT_DEF
    ; CHECK-NEXT: [[INSERT_SUBREG:%[0-9]+]]:g8rc = INSERT_SUBREG killed [[DEF1]], killed [[LWA_32_]], %subreg.sub_32
    ; CHECK-NEXT: $x3 = COPY killed [[INSERT_SUBREG]]
    ; CHECK-NEXT: BLR8 implicit $lr8, implicit $rm, implicit killed $x3
    %0:g8rc_and_g8rc_nox0 = COPY $x3
    %1:g8rc = LWZ8 0, %0 :: (load (s32))
    %2:gprc = EXTSW_32 %1.sub_32
    %3:g8rc = IMPLICIT_DEF
    %4:g8rc = INSERT_SUBREG %3, %2, %subreg.sub_32
    $x3 = COPY %4
    BLR8 implicit $lr8, implicit $rm, implicit $x3
...

# 32-bit result EXTSW_32, indexed load.
---
name:            extsw32_lwzx8_subreg_input
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $x3, $x4
    ; CHECK-LABEL: name: extsw32_lwzx8_subreg_input
    ; CHECK: liveins: $x3, $x4
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:g8rc_and_g8rc_nox0 = COPY killed $x3
    ; CHECK-NEXT: [[COPY1:%[0-9]+]]:g8rc = COPY killed $x4
    ; CHECK-NEXT: [[LWAX_32_:%[0-9]+]]:gprc = LWAX_32 killed [[COPY]], killed [[COPY1]] :: (load (s32))
    ; CHECK-NEXT: dead [[DEF:%[0-9]+]]:g8rc = IMPLICIT_DEF
    ; CHECK-NEXT: [[DEF1:%[0-9]+]]:g8rc = IMPLICIT_DEF
    ; CHECK-NEXT: [[INSERT_SUBREG:%[0-9]+]]:g8rc = INSERT_SUBREG killed [[DEF1]], killed [[LWAX_32_]], %subreg.sub_32
    ; CHECK-NEXT: $x3 = COPY killed [[INSERT_SUBREG]]
    ; CHECK-NEXT: BLR8 implicit $lr8, implicit $rm, implicit killed $x3
    %0:g8rc_and_g8rc_nox0 = COPY $x3
    %5:g8rc = COPY $x4
    %1:g8rc = LWZX8 %0, %5 :: (load (s32))
    %2:gprc = EXTSW_32 %1.sub_32
    %3:g8rc = IMPLICIT_DEF
    %4:g8rc = INSERT_SUBREG %3, %2, %subreg.sub_32
    $x3 = COPY %4
    BLR8 implicit $lr8, implicit $rm, implicit $x3
...

# Negative test: no fold, the D-form displacement is not 4-byte aligned.
---
name:            extsw_lwz8_subreg_input_unaligned
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $x3
    ; CHECK-LABEL: name: extsw_lwz8_subreg_input_unaligned
    ; CHECK: liveins: $x3
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:g8rc_and_g8rc_nox0 = COPY killed $x3
    ; CHECK-NEXT: [[LWZ8_:%[0-9]+]]:g8rc = LWZ8 2, killed [[COPY]] :: (load (s32))
    ; CHECK-NEXT: [[EXTSW_32_64_:%[0-9]+]]:g8rc = EXTSW_32_64 killed [[LWZ8_]].sub_32
    ; CHECK-NEXT: $x3 = COPY killed [[EXTSW_32_64_]]
    ; CHECK-NEXT: BLR8 implicit $lr8, implicit $rm, implicit killed $x3
    %0:g8rc_and_g8rc_nox0 = COPY $x3
    %1:g8rc = LWZ8 2, %0 :: (load (s32))
    %2:g8rc = EXTSW_32_64 %1.sub_32
    $x3 = COPY %2
    BLR8 implicit $lr8, implicit $rm, implicit $x3
...

# Negative test: no fold, the load has another use besides the sign-extension.
---
name:            extsw_lwz8_subreg_input_multiuse
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $x3
    ; CHECK-LABEL: name: extsw_lwz8_subreg_input_multiuse
    ; CHECK: liveins: $x3
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:g8rc_and_g8rc_nox0 = COPY killed $x3
    ; CHECK-NEXT: [[LWZ8_:%[0-9]+]]:g8rc = LWZ8 0, killed [[COPY]] :: (load (s32))
    ; CHECK-NEXT: [[EXTSW_32_64_:%[0-9]+]]:g8rc = EXTSW_32_64 [[LWZ8_]].sub_32
    ; CHECK-NEXT: $x3 = COPY killed [[EXTSW_32_64_]]
    ; CHECK-NEXT: $x4 = COPY killed [[LWZ8_]]
    ; CHECK-NEXT: BLR8 implicit $lr8, implicit $rm, implicit killed $x3, implicit killed $x4
    %0:g8rc_and_g8rc_nox0 = COPY $x3
    %1:g8rc = LWZ8 0, %0 :: (load (s32))
    %2:g8rc = EXTSW_32_64 %1.sub_32
    $x3 = COPY %2
    $x4 = COPY %1
    BLR8 implicit $lr8, implicit $rm, implicit $x3, implicit $x4
...
