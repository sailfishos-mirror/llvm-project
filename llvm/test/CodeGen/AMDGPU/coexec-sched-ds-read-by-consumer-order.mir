# RUN: llc -mtriple=amdgcn -mcpu=gfx1250 -run-pass=machine-scheduler \
# RUN:     -amdgpu-sched-strategy=coexec -verify-misched \
# RUN:     -debug-only=machine-scheduler %s -o /dev/null 2>&1 \
# RUN:   | FileCheck -check-prefixes=ON,MIXED %s
#
# REQUIRES: asserts
#
# Smoke test for the DS_READ-by-consumer-order tie-breaker
# (CandidateHeuristics::tryDSReadByConsumerOrder, threaded into
# tryCandidateCoexec).
#
# The heuristic recognises a "K-loop body" pattern in a single-MBB natural
# loop, where some VGPRs produced by tail DS_READs are consumed near the
# top of the next iteration. Bad DS_READ schedule at the bottom causes
# immediate consumption at the top. This heuristic tries to avoid that.

--- |
  define void @ds_read_by_consumer_order_self_loop() #0 { ret void }
  define void @ds_read_by_consumer_order_mixed_lane_lifetime() #0 { ret void }
  attributes #0 = { "amdgpu-waves-per-eu"="1,1" }
...

# Self-loop bb.1 -> bb.1 (with an exit edge bb.1 -> bb.2). MachineScheduler
# computes MachineLoopInfo as a required analysis even under
# `-run-pass=machine-scheduler`, so MLI sees bb.1 as a single-block natural
# loop and the whole-loop-body region detection (now a local lambda inside
# updateForScheduling) fires. In bb.1, %12 and %13 are consumed at the top
# (V_MOV_B32) and re-defined at the bottom by DS_READ_B128_gfx9 — the
# textbook post-PHI signature of loop-carried DS_READ-produced VGPRs.

---
name: ds_read_by_consumer_order_self_loop
tracksRegLiveness: true
isSSA: false
body: |
  bb.0:
    successors: %bb.1
    %5:vgpr_32 = IMPLICIT_DEF
    %12:vreg_128_lo256_align2 = IMPLICIT_DEF
    %13:vreg_128_lo256_align2 = IMPLICIT_DEF
    %22:sreg_32 = IMPLICIT_DEF
    S_BRANCH %bb.1

  bb.1:
    successors: %bb.1, %bb.2
    %30:vgpr_32 = V_MOV_B32_e32 %12.sub0, implicit $exec
    %31:vgpr_32 = V_MOV_B32_e32 %13.sub0, implicit $exec
    %12:vreg_128_lo256_align2 = DS_READ_B128_gfx9 %5, 0, 0, implicit $exec
    %13:vreg_128_lo256_align2 = DS_READ_B128_gfx9 %5, 16, 0, implicit $exec
    S_CMP_LG_U32 %22, 0, implicit-def $scc
    S_CBRANCH_SCC1 %bb.1, implicit $scc
    S_BRANCH %bb.2

  bb.2:
    S_ENDPGM 0, implicit %12, implicit %13, implicit %30, implicit %31
...

# With the heuristic enabled, the seed scan must find at least one
# loop-carried DS_READ lane slice and the recording phase must fire on
# at least the first top-of-loop consumer.
# ON: DSReadByConsumerOrder: loop-carried DS_READ slices ({{[1-9][0-9]*}} across {{[1-9][0-9]*}} vregs):
# ON: DSReadByConsumerOrder: SU({{[0-9]+}}) consumes {{.*}} at pos 0

# Lane-precise mixed-lifetime test. %12 is a 256-bit vreg loaded by two
# partial DS_READs that fill disjoint halves:
#   - lower half  (sub0_sub1_sub2_sub3) is consumed IN-ITER, after its def
#   - upper half  (sub4_sub5_sub6_sub7) is consumed only at the top of the
#                                       next iteration (loop-carried)
# The per-vreg classifier would reject %12 outright because it sees a use
# (the in-iter sub0 reader) AFTER the last DS_READ def. The lane-precise
# classifier must split %12's lifetime by sub-reg and recognise that the
# upper-half slice is still loop-carried. Concretely:
#   - the seed banner must list %12 (with a non-empty lane mask), AND
#   - a top-of-loop "consumes %12 lanes=<mask>" trace must fire for that
#     slice.

---
name: ds_read_by_consumer_order_mixed_lane_lifetime
tracksRegLiveness: true
isSSA: false
body: |
  bb.0:
    successors: %bb.1
    %5:vgpr_32 = IMPLICIT_DEF
    %12:vreg_256_align2 = IMPLICIT_DEF
    %22:sreg_32 = IMPLICIT_DEF
    S_BRANCH %bb.1

  bb.1:
    successors: %bb.1, %bb.2
    ; Top of loop: only the UPPER half of %12 (specifically sub4) is read
    ; from the previous iteration. This is the loop-carried consumer.
    %30:vgpr_32 = V_MOV_B32_e32 %12.sub4, implicit $exec

    ; Two partial DS_READ defs of %12 — lower half then upper half.
    undef %12.sub0_sub1_sub2_sub3:vreg_256_align2 = DS_READ_B128_gfx9 %5, 0, 0, implicit $exec
    %12.sub4_sub5_sub6_sub7:vreg_256_align2       = DS_READ_B128_gfx9 %5, 16, 0, implicit $exec

    ; IN-ITER consumer of the LOWER half AFTER its def. Under the per-vreg
    ; classifier this single use would poison %12 entirely (LastUsePos >
    ; LastDSReadDefPos). Lane-precise tracking confines the rejection to
    ; the sub0 lane and keeps sub4 loop-carried.
    %31:vgpr_32 = V_MOV_B32_e32 %12.sub0, implicit $exec

    S_CMP_LG_U32 %22, 0, implicit-def $scc
    S_CBRANCH_SCC1 %bb.1, implicit $scc
    S_BRANCH %bb.2

  bb.2:
    S_ENDPGM 0, implicit %12, implicit %30, implicit %31
...

# Banner for the mixed function must report exactly 1 LC vreg (only the
# upper-half lane survives the per-slice LC test); the per-vreg list
# carries the upper-half lane mask 0x0000_0000_0000_0300 (sub4 of an
# align2 256-bit class). The MIXED prefix is checked alongside ON in the
# same llc run (two functions emitted in sequence; MIR resets vreg
# numbering per function, so the source %12 is renamed by the parser).
# MIXED: DSReadByConsumerOrder: loop-carried DS_READ slices ({{[1-9][0-9]*}} across 1 vregs): %{{[0-9]+}}[0000000000000300]

# The recording phase must fire on the same upper-half slice from the
# top-of-loop consumer (V_MOV_B32 reading %12.sub4).
# MIXED: DSReadByConsumerOrder: SU({{[0-9]+}}) consumes %{{[0-9]+}} lanes=0000000000000300 at pos {{[0-9]+}}
