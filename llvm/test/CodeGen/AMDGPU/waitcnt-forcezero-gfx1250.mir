# GFX1200-NEXT: S_WAIT_SAMPLECNT 0
# GFX1200-NEXT: S_WAIT_BVHCNT 0
# GFX1200-NEXT: S_WAIT_KMCNT 0
# GFX1200-NEXT: S_NOP 0
# GFX1200-NOT: S_WAIT_XCNT
# GFX1200-NOT: S_WAIT_ASYNCCNT
# GFX1200-NOT: S_WAIT_TENSORCNT

