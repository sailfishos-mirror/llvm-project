; CHECK-NEXT:    [[SEL:%.*]] = select i1 [[C]], ptr [[STORAGE]], ptr [[G]]
; CHECK-NEXT:    store i32 5, ptr [[SEL]], align 4
; CHECK-NEXT:    ret void
;
