# RUN: llc -mtriple=amdgcn-amd-amdhsa -mcpu=gfx1250 -run-pass=si-insert-waitcnts -o - %s | FileCheck %s

---
name:            soft_wait_before_s_barrier
tracksRegLiveness: true
machineFunctionInfo:
  isEntryFunction: true
body:             |
  ; CHECK-LABEL: name: soft_wait_before_s_barrier
  ; CHECK: bb.0:
  ; CHECK-NEXT:   successors: %bb.1(0x80000000)
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   renamable $vgpr17 = V_MOV_B32_e32 0, implicit $exec
  ; CHECK-NEXT:   renamable $vgpr32_vgpr33 = V_MOV_B64_e32 0, implicit $exec
  ; CHECK-NEXT:   $vcc_lo = S_MOV_B32 $exec_lo
  ; CHECK-NEXT:   renamable $vgpr0 = DS_READ_B32_gfx9 renamable $vgpr17, 0, 0, implicit $exec
  ; CHECK-NEXT:   S_WAIT_DSCNT 0
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.1:
  ; CHECK-NEXT:   successors: %bb.2(0x40000000), %bb.1(0x40000000)
  ; CHECK-NEXT:   liveins: $vgpr32_vgpr33, $vgpr17, $vgpr0, $vcc_lo
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   S_WAIT_DSCNT 0
  ; CHECK-NEXT:   S_BARRIER_SIGNAL_IMM -1
  ; CHECK-NEXT:   $vgpr1 = V_MOV_B32_e32 $vgpr0, implicit $exec
  ; CHECK-NEXT:   GLOBAL_LOAD_ASYNC_TO_LDS_B64 $vgpr17, $vgpr32_vgpr33, 0, 0, implicit-def dead $asynccnt, implicit $exec, implicit $asynccnt
  ; CHECK-NEXT:   S_CBRANCH_VCCNZ %bb.1, implicit $vcc_lo, implicit $vcc_lo
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.2:
  ; CHECK-NEXT:   S_ENDPGM 0
  bb.0:
    successors: %bb.1

    renamable $vgpr17 = V_MOV_B32_e32 0, implicit $exec
    renamable $vgpr32_vgpr33 = V_MOV_B64_e32 0, implicit $exec
    $vcc_lo = S_MOV_B32 $exec_lo
    renamable $vgpr0 = DS_READ_B32_gfx9 renamable $vgpr17, 0, 0, implicit $exec

  bb.1:
    successors: %bb.2, %bb.1
    liveins: $vgpr32_vgpr33, $vgpr17, $vgpr0, $vcc_lo

    S_WAIT_DSCNT_soft 0
    S_BARRIER_SIGNAL_IMM -1
    $vgpr1 = V_MOV_B32_e32 $vgpr0, implicit $exec
    GLOBAL_LOAD_ASYNC_TO_LDS_B64 $vgpr17, $vgpr32_vgpr33, 0, 0, implicit-def dead $asynccnt, implicit $exec, implicit $asynccnt
    S_CBRANCH_VCCNZ %bb.1, implicit $vcc_lo, implicit $vcc

  bb.2:
    S_ENDPGM 0
...

---
name:            soft_wait_multipath_first_pred_needs_wait
tracksRegLiveness: true
machineFunctionInfo:
  isEntryFunction: true
body:             |
  ; CHECK-LABEL: name: soft_wait_multipath_first_pred_needs_wait
  ; CHECK: bb.0:
  ; CHECK-NEXT:   successors: %bb.1(0x40000000), %bb.2(0x40000000)
  ; CHECK-NEXT:   liveins: $sgpr0
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   $vgpr0 = V_MOV_B32_e32 0, implicit $exec
  ; CHECK-NEXT:   S_CMP_EQ_U32 $sgpr0, 0, implicit-def $scc
  ; CHECK-NEXT:   S_CBRANCH_SCC1 %bb.2, implicit $scc
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.1:
  ; CHECK-NEXT:   successors: %bb.3(0x80000000)
  ; CHECK-NEXT:   liveins: $vgpr0
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   $vgpr1 = DS_READ_B32_gfx9 $vgpr0, 0, 0, implicit $exec
  ; CHECK-NEXT:   S_BRANCH %bb.3
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.2:
  ; CHECK-NEXT:   successors: %bb.3(0x80000000)
  ; CHECK-NEXT:   liveins: $vgpr0
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   $vgpr1 = V_MOV_B32_e32 42, implicit $exec
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.3:
  ; CHECK-NEXT:   liveins: $vgpr0, $vgpr1
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   S_WAIT_DSCNT 0
  ; CHECK-NEXT:   S_BARRIER_SIGNAL_IMM -1
  ; CHECK-NEXT:   $vgpr2 = V_MOV_B32_e32 $vgpr1, implicit $exec
  ; CHECK-NEXT:   S_ENDPGM 0
  bb.0:
    successors: %bb.1(0x40000000), %bb.2(0x40000000)
    liveins: $sgpr0

    $vgpr0 = V_MOV_B32_e32 0, implicit $exec
    S_CMP_EQ_U32 $sgpr0, 0, implicit-def $scc
    S_CBRANCH_SCC1 %bb.2, implicit $scc

  bb.1:
    ; This path has a DS read that needs to be waited on
    successors: %bb.3(0x80000000)
    liveins: $vgpr0

    $vgpr1 = DS_READ_B32_gfx9 $vgpr0, 0, 0, implicit $exec
    S_BRANCH %bb.3

  bb.2:
    ; This path has NO pending DS operations - just a simple mov
    successors: %bb.3(0x80000000)
    liveins: $vgpr0

    $vgpr1 = V_MOV_B32_e32 42, implicit $exec

  bb.3:
    liveins: $vgpr0, $vgpr1

    S_WAIT_DSCNT_soft 0
    S_BARRIER_SIGNAL_IMM -1
    $vgpr2 = V_MOV_B32_e32 $vgpr1, implicit $exec
    S_ENDPGM 0
...

---
name:            soft_wait_second_pred_needs_wait
tracksRegLiveness: true
machineFunctionInfo:
  isEntryFunction: true
body:             |
  ; CHECK-LABEL: name: soft_wait_second_pred_needs_wait
  ; CHECK: bb.0:
  ; CHECK-NEXT:   successors: %bb.1(0x40000000), %bb.2(0x40000000)
  ; CHECK-NEXT:   liveins: $sgpr0
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   $vgpr0 = V_MOV_B32_e32 0, implicit $exec
  ; CHECK-NEXT:   S_CMP_EQ_U32 $sgpr0, 0, implicit-def $scc
  ; CHECK-NEXT:   S_CBRANCH_SCC1 %bb.2, implicit $scc
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.1:
  ; CHECK-NEXT:   successors: %bb.3(0x80000000)
  ; CHECK-NEXT:   liveins: $vgpr0
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   $vgpr1 = V_MOV_B32_e32 42, implicit $exec
  ; CHECK-NEXT:   S_BRANCH %bb.3
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.2:
  ; CHECK-NEXT:   successors: %bb.3(0x80000000)
  ; CHECK-NEXT:   liveins: $vgpr0
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   $vgpr1 = DS_READ_B32_gfx9 $vgpr0, 0, 0, implicit $exec
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.3:
  ; CHECK-NEXT:   liveins: $vgpr0, $vgpr1
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   S_WAIT_DSCNT 0
  ; CHECK-NEXT:   $vgpr2 = V_MOV_B32_e32 $vgpr1, implicit $exec
  ; CHECK-NEXT:   S_ENDPGM 0
  bb.0:
    successors: %bb.1(0x40000000), %bb.2(0x40000000)
    liveins: $sgpr0

    $vgpr0 = V_MOV_B32_e32 0, implicit $exec
    S_CMP_EQ_U32 $sgpr0, 0, implicit-def $scc
    S_CBRANCH_SCC1 %bb.2, implicit $scc

  bb.1:
    ; FIRST path in RPO order: NO pending DS operations
    successors: %bb.3(0x80000000)
    liveins: $vgpr0

    $vgpr1 = V_MOV_B32_e32 42, implicit $exec
    S_BRANCH %bb.3

  bb.2:
    ; SECOND path in RPO order: HAS pending DS read
    successors: %bb.3(0x80000000)
    liveins: $vgpr0

    $vgpr1 = DS_READ_B32_gfx9 $vgpr0, 0, 0, implicit $exec

  bb.3:
    ; Soft wait must be kept - bb.2 has pending DS read
    ; bb.1 has no pending events, so SeenPredecessors only has bb.2
    ; But pred_size=2, so AllowWaitDeletion should be false
    liveins: $vgpr0, $vgpr1

    S_WAIT_DSCNT_soft 0
    $vgpr2 = V_MOV_B32_e32 $vgpr1, implicit $exec
    S_ENDPGM 0
...
