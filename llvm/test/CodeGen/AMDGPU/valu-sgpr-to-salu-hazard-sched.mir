# NOTE: Assertions have been autogenerated by utils/update_mir_test_checks.py UTC_ARGS: --version 6
# RUN: llc -mtriple=amdgcn -mcpu=gfx1250 -run-pass=machine-scheduler -verify-misched %s -o - | FileCheck -check-prefix=DEFAULT %s
# RUN: llc -mtriple=amdgcn -mcpu=gfx1250 -run-pass=machine-scheduler -amdgpu-sched-strategy=coexec -verify-misched %s -o - | FileCheck -check-prefix=COEXEC %s

# Test that SALU instructions are delayed after VALU instructions that read SGPR operands.
# When a VALU reads an SGPR, there is an 8-cycle hazard before SALU can execute.
# When V_READFIRSTLANE writes an SGPR, there is a 16-cycle hazard before SALU can execute.

--- |
  define void @valu_sgpr_with_fillable_delay() #0 { ret void }
  define void @readfirstlane_with_fillable_delay() #0 { ret void }

  attributes #0 = { "amdgpu-waves-per-eu"="1,1" }
...


---
# Test with enough VALU instructions to fill the 8-cycle hazard gap.
# When a VALU reads SGPR and there are enough independent VALUs to fill 8 cycles,
# the SALU can be scheduled after them without stall.
name: valu_sgpr_with_fillable_delay
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $sgpr0, $sgpr1, $sgpr2, $vgpr3
