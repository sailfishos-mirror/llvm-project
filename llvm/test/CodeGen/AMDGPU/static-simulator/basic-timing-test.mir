    ; PK16 instruction: 8 cycle VALU occupancy
    $vgpr8_vgpr9_vgpr10_vgpr11_vgpr12_vgpr13_vgpr14_vgpr15 = V_CVT_SCALE_PK16_F16_FP6_e64 $vgpr0_vgpr1_vgpr2, $vgpr3, 0, implicit $mode, implicit $exec
    ; These VALU instructions should stall waiting for VALU
    $vgpr20 = V_MOV_B32_e32 1, implicit $exec
    $vgpr21 = V_MOV_B32_e32 2, implicit $exec
