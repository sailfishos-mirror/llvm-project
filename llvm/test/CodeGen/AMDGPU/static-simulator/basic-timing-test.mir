    $sgpr20 = S_ADD_I32 $sgpr0, $sgpr4, implicit-def $scc
    $sgpr21 = S_ADD_I32 $sgpr0, $sgpr1, implicit-def $scc
    S_ENDPGM 0, implicit $sgpr20, implicit $sgpr21
...

