# RUN: llc -mtriple=amdgcn -mcpu=gfx1250 -amdgpu-enable-static-simulator -amdgpu-static-sim-verbose -debug-only=amdgpu-static-simulator -run-pass amdgpu-static-simulator %s -o /dev/null 2>&1 | FileCheck %s
# REQUIRES: asserts

---
# VALU with SGPR operand blocks following SALU until VALU result ready
name: valu_ssrc_stalls_salu
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $vgpr0, $sgpr0, $sgpr1, $sgpr2
    $vgpr10 = V_ADD_F32_e32 $sgpr0, $vgpr0, implicit $exec, implicit $mode
    $sgpr10 = S_ADD_I32 $sgpr1, $sgpr2, implicit-def $scc
    S_ENDPGM 0, implicit $sgpr10
...

# CHECK-LABEL: valu_ssrc_stalls_salu
# CHECK: V_ADD_F32_e32 $sgpr0
# CHECK: Latency: 5
# CHECK: S_ADD_I32
# CHECK: Stalls: SSRC=4
# CHECK: VaSSRC:4

---
# VALU without SGPR doesn't block SALU (negative test)
name: valu_no_ssrc_no_stall
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $vgpr0, $vgpr1, $sgpr0, $sgpr1
    $vgpr10 = V_ADD_F32_e32 $vgpr0, $vgpr1, implicit $exec, implicit $mode
    $sgpr10 = S_ADD_I32 $sgpr0, $sgpr1, implicit-def $scc
    S_ENDPGM 0, implicit $sgpr10
...

# CHECK-LABEL: valu_no_ssrc_no_stall
# CHECK: V_ADD_F32_e32 $vgpr0
# CHECK: Stalls: (none)
# CHECK: S_ADD_I32
# CHECK: Stalls: (none)
