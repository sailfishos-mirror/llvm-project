# RUN: llc -mtriple=amdgcn -mcpu=gfx1250 -amdgpu-enable-static-simulator -amdgpu-static-sim-verbose -debug-only=amdgpu-static-simulator -run-pass amdgpu-static-simulator %s -o /dev/null 2>&1 | FileCheck %s
# REQUIRES: asserts

---
# s_delay_alu with instskip: instid0 applies immediately, instid1 after skip
name: delay_alu_skip_with_stall
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $vgpr0, $vgpr1, $vgpr2
    $vgpr0 = V_ADD_F32_e32 $vgpr1, $vgpr2, implicit $mode, implicit $exec
    S_DELAY_ALU 145  ; instid0=VALU_DEP_1, skip=1, instid1=VALU_DEP_1 (instid0 stalls here)
    $vgpr10 = V_MOV_B32_e32 $vgpr0, implicit $exec   ; no stall, RAW satisfied
    $vgpr11 = V_MOV_B32_e32 0, implicit $exec        ; instid1 applies here (after skip=1)
    $vgpr12 = V_MOV_B32_e32 $vgpr10, implicit $exec  ; no stall, vgpr10 ready
    S_ENDPGM 0
...

# CHECK-LABEL: delay_alu_skip_with_stall
# CHECK: V_ADD_F32_e32
# CHECK: S_DELAY_ALU
# CHECK: DelayALU: instid0=1 (stall {{[0-9]+}}), skip=1, instid1=1 (pending)
# CHECK: V_MOV_B32_e32 $vgpr0
# CHECK: Stalls: (none)
# CHECK: V_MOV_B32_e32 0
# CHECK: PendingInstId1: Dep=1 stall=
# CHECK: V_MOV_B32_e32 $vgpr10

---
# s_delay_alu with only instid0, no skip
name: delay_alu_no_skip
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $vgpr0, $vgpr1
    $vgpr0 = V_ADD_F32_e32 $vgpr0, $vgpr1, implicit $mode, implicit $exec
    S_DELAY_ALU 1  ; instid0=VALU_DEP_1
    $vgpr10 = V_MOV_B32_e32 $vgpr0, implicit $exec
    S_ENDPGM 0
...

# CHECK-LABEL: delay_alu_no_skip
# CHECK: V_ADD_F32_e32
# CHECK: S_DELAY_ALU
# CHECK: DelayALU: instid0=1 (stall {{[0-9]+}})
# CHECK-NOT: pending
# CHECK: V_MOV_B32_e32
# CHECK: Stalls: (none)
