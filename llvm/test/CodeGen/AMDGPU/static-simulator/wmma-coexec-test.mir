# V_EXP at I-slot (cycle 7), back-to-back non-scaled WMMA at V-slot (cycle 8), no stall
# CHECK-LABEL: trans_rule_exp_then_wmma
# CHECK: End BB#0: 10 insts, 10 cycles, 0 stalls
name: trans_rule_exp_then_wmma
tracksRegLiveness: true
