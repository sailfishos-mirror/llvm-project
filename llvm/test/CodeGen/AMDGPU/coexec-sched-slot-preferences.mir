name: wmma_f16_16x16x32_avoidances
tracksRegLiveness: true
body: |
  ; CHECK-LABEL: name: wmma_f16_16x16x32_avoidances
  ; CHECK: bb.0:
  ; CHECK-NEXT:   successors: %bb.1(0x80000000)
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   [[DEF:%[0-9]+]]:vreg_256_align2 = IMPLICIT_DEF
