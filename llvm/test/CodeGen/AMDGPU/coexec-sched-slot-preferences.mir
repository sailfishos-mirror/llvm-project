    early-clobber %18:vreg_256_align2 = V_WMMA_F32_16X16X32_F16_w32_twoaddr 8, %3, 8, %4, 8, %5, 0, 0, 0, 0, implicit $exec
    S_ENDPGM 0, implicit %10, implicit %11, implicit %12, implicit %13, implicit %16, implicit %17, implicit %18
