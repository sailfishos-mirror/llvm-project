    %14:sreg_32 = S_ADD_I32 %9, %9, implicit-def dead $scc
    %15:sreg_32 = S_ADD_I32 %14, %9, implicit-def dead $scc
    %16:sreg_32 = S_ADD_I32 %15, %9, implicit-def dead $scc
