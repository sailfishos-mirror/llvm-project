  ; CHECK-NEXT:   [[DEF8:%[0-9]+]]:vgpr_32 = IMPLICIT_DEF
  ; CHECK-NEXT:   [[DEF9:%[0-9]+]]:sreg_32 = IMPLICIT_DEF
  ; CHECK-NEXT:   S_BRANCH %bb.1
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.1:
  ; CHECK-NEXT:   early-clobber %17:vreg_256_align2 = V_WMMA_F32_16X16X32_F16_w32_twoaddr 8, [[DEF]], 8, [[DEF1]], 8, [[DEF2]], 0, 0, 0, 0, implicit $exec
  ; CHECK-NEXT:   [[S_ADD_I32_:%[0-9]+]]:sreg_32 = S_ADD_I32 [[DEF9]], [[DEF9]], implicit-def dead $scc
  ; CHECK-NEXT:   [[V_ADD_F32_e32_:%[0-9]+]]:vgpr_32 = nofpexcept V_ADD_F32_e32 [[DEF7]], [[DEF8]], implicit $mode, implicit $exec
  ; CHECK-NEXT:   [[V_EXP_F32_e32_:%[0-9]+]]:vgpr_32 = nofpexcept V_EXP_F32_e32 [[DEF7]], implicit $mode, implicit $exec
  ; CHECK-NEXT:   [[DS_READ_B128_gfx9_:%[0-9]+]]:vreg_128_lo256_align2 = DS_READ_B128_gfx9 [[DEF6]], 0, 0, implicit $exec
  ; CHECK-NEXT:   [[S_ADD_I32_1:%[0-9]+]]:sreg_32 = S_ADD_I32 [[S_ADD_I32_]], [[DEF9]], implicit-def dead $scc
  ; CHECK-NEXT:   [[V_MUL_F32_e32_:%[0-9]+]]:vgpr_32 = nofpexcept V_MUL_F32_e32 [[DEF7]], [[DEF8]], implicit $mode, implicit $exec
  ; CHECK-NEXT:   [[S_ADD_I32_2:%[0-9]+]]:sreg_32 = S_ADD_I32 [[S_ADD_I32_1]], [[DEF9]], implicit-def dead $scc
  ; CHECK-NEXT:   early-clobber %18:vreg_256_align2 = V_WMMA_F32_16X16X32_F16_w32_twoaddr 8, [[DEF3]], 8, [[DEF4]], 8, [[DEF5]], 0, 0, 0, 0, implicit $exec
  ; CHECK-NEXT:   S_ENDPGM 0, implicit [[DS_READ_B128_gfx9_]], implicit [[V_ADD_F32_e32_]], implicit [[V_MUL_F32_e32_]], implicit [[V_EXP_F32_e32_]], implicit [[S_ADD_I32_2]], implicit %17, implicit %18
  bb.0:
    successors: %bb.1
    ; WMMA operands (first)
    %0:vreg_256_align2 = IMPLICIT_DEF
    %1:vreg_256_align2 = IMPLICIT_DEF
    %2:vreg_256_align2 = IMPLICIT_DEF
    ; WMMA operands (second)
    %3:vreg_256_align2 = IMPLICIT_DEF
    %4:vreg_256_align2 = IMPLICIT_DEF
    %5:vreg_256_align2 = IMPLICIT_DEF
    ; DS addresses
