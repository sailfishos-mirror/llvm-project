    ; VALU operands
    %7:vgpr_32 = IMPLICIT_DEF
    %8:vgpr_32 = IMPLICIT_DEF
    ; SALU operand
    %9:sreg_32 = IMPLICIT_DEF
    S_BRANCH %bb.1

  bb.1:
    ; DS - avoided at slots 1, 5 (should go to slot 4)
    %10:vreg_128_lo256_align2 = DS_READ_B128_gfx9 %6, 0, 0, implicit $exec
    ; VALU
    %11:vgpr_32 = nofpexcept V_ADD_F32_e32 %7, %8, implicit $mode, implicit $exec
