    %12:sreg_32 = S_ADD_I32 %9, %9, implicit-def dead $scc
    ; Two WMMAs
    early-clobber %13:vreg_256_align2 = V_WMMA_F32_16X16X64_FP8_FP8_w32_threeaddr %0, %1, 8, %2, 0, 0, 0, 0, implicit $exec
    early-clobber %14:vreg_256_align2 = V_WMMA_F32_16X16X64_FP8_FP8_w32_threeaddr %3, %4, 8, %5, 0, 0, 0, 0, implicit $exec
    S_ENDPGM 0, implicit %10, implicit %11, implicit %12, implicit %13, implicit %14
...

#############################################################################
# V_WMMA_F32_16X16X32_F16 (non-scaled): Pattern "0EIIEEIIV"
#
# Preferences:
#   Slot 2 (I0): SingleCycleVALU
#   Slot 3 (I1): TRANS
#   Slot 4 (E1): DS
#   Slot 6 (I2): SingleCycleVALU
#   Slot 8 (V0): WMMA
#
# Avoidances:
#   Slot 1 (E0): DS
#   Slot 5 (E2): DS
#############################################################################

---
name: wmma_f16_16x16x32_preferences
tracksRegLiveness: true
body: |
  ; CHECK-LABEL: name: wmma_f16_16x16x32_preferences
  ; CHECK: bb.0:
  ; CHECK-NEXT:   successors: %bb.1(0x80000000)
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   [[DEF:%[0-9]+]]:vreg_256_align2 = IMPLICIT_DEF
  ; CHECK-NEXT:   [[DEF1:%[0-9]+]]:vreg_256_align2 = IMPLICIT_DEF
  ; CHECK-NEXT:   [[DEF2:%[0-9]+]]:vreg_256_align2 = IMPLICIT_DEF
  ; CHECK-NEXT:   [[DEF3:%[0-9]+]]:vreg_256_align2 = IMPLICIT_DEF
  ; CHECK-NEXT:   [[DEF4:%[0-9]+]]:vreg_256_align2 = IMPLICIT_DEF
  ; CHECK-NEXT:   [[DEF5:%[0-9]+]]:vreg_256_align2 = IMPLICIT_DEF
  ; CHECK-NEXT:   [[DEF6:%[0-9]+]]:vgpr_32 = IMPLICIT_DEF
  ; CHECK-NEXT:   [[DEF7:%[0-9]+]]:vgpr_32 = IMPLICIT_DEF
  ; CHECK-NEXT:   [[DEF8:%[0-9]+]]:vgpr_32 = IMPLICIT_DEF
  ; CHECK-NEXT:   [[DEF9:%[0-9]+]]:sreg_32 = IMPLICIT_DEF
  ; CHECK-NEXT:   S_BRANCH %bb.1
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.1:
  ; CHECK-NEXT:   early-clobber %17:vreg_256_align2 = V_WMMA_F32_16X16X32_F16_w32_twoaddr 8, [[DEF]], 8, [[DEF1]], 8, [[DEF2]], 0, 0, 0, 0, implicit $exec
  ; CHECK-NEXT:   [[S_ADD_I32_:%[0-9]+]]:sreg_32 = S_ADD_I32 [[DEF9]], [[DEF9]], implicit-def dead $scc
  ; CHECK-NEXT:   [[V_ADD_F32_e32_:%[0-9]+]]:vgpr_32 = nofpexcept V_ADD_F32_e32 [[DEF7]], [[DEF8]], implicit $mode, implicit $exec
  ; CHECK-NEXT:   [[V_EXP_F32_e32_:%[0-9]+]]:vgpr_32 = nofpexcept V_EXP_F32_e32 [[DEF7]], implicit $mode, implicit $exec
  ; CHECK-NEXT:   [[DS_READ_B128_gfx9_:%[0-9]+]]:vreg_128_lo256_align2 = DS_READ_B128_gfx9 [[DEF6]], 0, 0, implicit $exec
  ; CHECK-NEXT:   [[S_ADD_I32_1:%[0-9]+]]:sreg_32 = S_ADD_I32 [[S_ADD_I32_]], [[DEF9]], implicit-def dead $scc
  ; CHECK-NEXT:   [[V_MUL_F32_e32_:%[0-9]+]]:vgpr_32 = nofpexcept V_MUL_F32_e32 [[DEF7]], [[DEF8]], implicit $mode, implicit $exec
  ; CHECK-NEXT:   [[S_ADD_I32_2:%[0-9]+]]:sreg_32 = S_ADD_I32 [[S_ADD_I32_1]], [[DEF9]], implicit-def dead $scc
  ; CHECK-NEXT:   early-clobber %18:vreg_256_align2 = V_WMMA_F32_16X16X32_F16_w32_twoaddr 8, [[DEF3]], 8, [[DEF4]], 8, [[DEF5]], 0, 0, 0, 0, implicit $exec
  ; CHECK-NEXT:   S_ENDPGM 0, implicit [[DS_READ_B128_gfx9_]], implicit [[V_ADD_F32_e32_]], implicit [[V_MUL_F32_e32_]], implicit [[V_EXP_F32_e32_]], implicit [[S_ADD_I32_2]], implicit %17, implicit %18
  bb.0:
    successors: %bb.1
    ; WMMA operands (first) - vreg_256 for A, B (F16); vreg_256 for C (F32)
    %0:vreg_256_align2 = IMPLICIT_DEF
    %1:vreg_256_align2 = IMPLICIT_DEF
    %2:vreg_256_align2 = IMPLICIT_DEF
    ; WMMA operands (second)
    %3:vreg_256_align2 = IMPLICIT_DEF
    %4:vreg_256_align2 = IMPLICIT_DEF
    %5:vreg_256_align2 = IMPLICIT_DEF
    ; DS address
    %6:vgpr_32 = IMPLICIT_DEF
    ; VALU operands
    %7:vgpr_32 = IMPLICIT_DEF
    %8:vgpr_32 = IMPLICIT_DEF
    ; SALU operand
    %9:sreg_32 = IMPLICIT_DEF
    S_BRANCH %bb.1

  bb.1:
    ; DS instruction (preferred at slot 4)
    %10:vreg_128_lo256_align2 = DS_READ_B128_gfx9 %6, 0, 0, implicit $exec
    ; SingleCycleVALU (preferred at slots 2, 6)
    %11:vgpr_32 = nofpexcept V_ADD_F32_e32 %7, %8, implicit $mode, implicit $exec
    %12:vgpr_32 = nofpexcept V_MUL_F32_e32 %7, %8, implicit $mode, implicit $exec
    ; TRANS instruction (preferred at slot 3)
    %13:vgpr_32 = nofpexcept V_EXP_F32_e32 %7, implicit $mode, implicit $exec
    ; SALU instructions (fill remaining E slots)
    %14:sreg_32 = S_ADD_I32 %9, %9, implicit-def dead $scc
    %15:sreg_32 = S_ADD_I32 %14, %9, implicit-def dead $scc
    %16:sreg_32 = S_ADD_I32 %15, %9, implicit-def dead $scc
    ; Two WMMAs (V slot prefers WMMA)
    early-clobber %17:vreg_256_align2 = V_WMMA_F32_16X16X32_F16_w32_twoaddr 8, %0, 8, %1, 8, %2, 0, 0, 0, 0, implicit $exec
    early-clobber %18:vreg_256_align2 = V_WMMA_F32_16X16X32_F16_w32_twoaddr 8, %3, 8, %4, 8, %5, 0, 0, 0, 0, implicit $exec
    S_ENDPGM 0, implicit %10, implicit %11, implicit %12, implicit %13, implicit %16, implicit %17, implicit %18
