# REQUIRES: asserts
# RUN: llc -mtriple=amdgcn -mcpu=gfx1250 -run-pass=machine-scheduler -amdgpu-sched-strategy=coexec -debug-only=machine-scheduler %s -filetype=null 2>&1 | FileCheck %s


--- |
  define void @test_flavor_classification() #0 { ret void }
  define void @repeat_rate_arith_i64() #0 { ret void }
  define void @repeat_rate_cvt_scale_pk8() #0 { ret void }
  define void @repeat_rate_cvt_f64() #0 { ret void }
  define void @repeat_rate_cmp_f64() #0 { ret void }
  define void @repeat_rate_arith_f64() #0 { ret void }
  define void @repeat_rate_shift_64() #0 { ret void }
  define void @repeat_rate_swap() #0 { ret void }
  define void @repeat_rate_int_mul() #0 { ret void }


  attributes #0 = { "amdgpu-waves-per-eu"="1,1" }
...

# CHECK-LABEL: test_flavor_classification:
# CHECK: HWUI Resource Pressure:
# CHECK-DAG: VMEM: 10 cycles, 10 instrs
# CHECK-DAG: DS: 4 cycles, 4 instrs
# CHECK-DAG: DMA: 4 cycles, 2 instrs
# CHECK-DAG: VALU(1c): 2 cycles, 2 instrs
# CHECK-DAG: VALU(Nc): 36 cycles, 2 instrs
# CHECK-DAG: TRANS: 4 cycles, 2 instrs


---
name: test_flavor_classification
tracksRegLiveness: true
body: |
  bb.0:
    %0:vreg_64_align2 = IMPLICIT_DEF
    %1:sgpr_128 = IMPLICIT_DEF
    %2:vgpr_32 = IMPLICIT_DEF
    %3:sgpr_256 = IMPLICIT_DEF
    %4:vreg_256_align2 = IMPLICIT_DEF

    %5:vgpr_32 = GLOBAL_LOAD_DWORD %0, 0, 0, implicit $exec
    %6:vreg_64_align2 = GLOBAL_LOAD_DWORDX2 %0, 8, 0, implicit $exec

    %7:vgpr_32 = BUFFER_LOAD_DWORD_OFFEN %2, %1, 0, 0, 0, 0, implicit $exec
    %8:vreg_64_align2 = BUFFER_LOAD_DWORDX2_OFFEN %2, %1, 0, 0, 0, 0, implicit $exec

    %9:vgpr_32 = FLAT_LOAD_DWORD %0, 0, 0, implicit $exec, implicit $flat_scr
    %10:vreg_64_align2 = FLAT_LOAD_DWORDX2 %0, 0, 0, implicit $exec, implicit $flat_scr

    GLOBAL_STORE_DWORD %0, %5, 0, 0, implicit $exec
    GLOBAL_STORE_DWORDX2 %0, %6, 0, 0, implicit $exec

    BUFFER_STORE_DWORD_OFFEN %5, %2, %1, 0, 0, 0, 0, implicit $exec
    BUFFER_STORE_DWORDX2_OFFEN %6, %2, %1, 0, 0, 0, 0, implicit $exec

    %11:vgpr_32 = DS_READ_B32 %2, 0, 0, implicit $m0, implicit $exec
    %12:vreg_64_align2 = DS_READ_B64 %2, 0, 0, implicit $m0, implicit $exec

    DS_WRITE_B32 %2, %5, 0, 0, implicit $m0, implicit $exec
    DS_WRITE_B64 %2, %6, 0, 0, implicit $m0, implicit $exec

    TENSOR_LOAD_TO_LDS_d2 %1, %3, 0, 0, implicit-def dead $tensorcnt, implicit $exec, implicit $tensorcnt
    GLOBAL_LOAD_ASYNC_TO_LDS_B32 %2, %0, 0, 0, implicit-def $asynccnt, implicit $exec, implicit $asynccnt

    %13:vreg_64_align2 = V_PK_ADD_F32 8, %6, 8, %6, 0, 0, 0, 0, 0, implicit $mode, implicit $exec
    %14:vgpr_32 = V_PERM_B32_e64 %5, %7, 84148480, implicit $exec
    %15:vreg_64_align2 = V_MIN_I64_e64 %6, %8, implicit $exec
    %16:vreg_64_align2 = V_CVT_SCALEF32_PK8_FP8_F32_e64 %4, %5, implicit $mode, implicit $exec

    %17:vgpr_32 = V_EXP_F32_e32 %5, implicit $exec, implicit $mode
    %18:vgpr_32 = V_EXP_F32_e32 %7, implicit $exec, implicit $mode

    S_ENDPGM 0, implicit %5, implicit %6, implicit %7, implicit %8, implicit %9, implicit %10, implicit %11, implicit %12, implicit %13, implicit %14, implicit %15, implicit %16, implicit %17, implicit %18
...

# CHECK-LABEL: repeat_rate_arith_i64:
# CHECK: VALU(Nc): 32 cycles, 1 instrs

---
name: repeat_rate_arith_i64
tracksRegLiveness: true
body: |
  bb.0:
    %0:vreg_64_align2 = IMPLICIT_DEF
    %1:vreg_64_align2 = V_MIN_I64_e64 %0, %0, implicit $exec

    S_ENDPGM 0, implicit %1
...

# CHECK-LABEL: repeat_rate_cvt_scale_pk8:
# CHECK: VALU(Nc): 4 cycles, 1 instrs

---
name: repeat_rate_cvt_scale_pk8
tracksRegLiveness: true
body: |
  bb.0:
    %0:vreg_256_align2 = IMPLICIT_DEF
    %1:vgpr_32 = IMPLICIT_DEF
    %2:vreg_64_align2 = V_CVT_SCALEF32_PK8_FP8_F32_e64 %0, %1, implicit $mode, implicit $exec

    S_ENDPGM 0, implicit %2
...

# CHECK-LABEL: repeat_rate_cvt_f64:
# CHECK: VALU(Nc): 32 cycles, 1 instrs

---
name: repeat_rate_cvt_f64
tracksRegLiveness: true
body: |
  bb.0:
    %0:vreg_64_align2 = IMPLICIT_DEF
    %1:vgpr_32 = nofpexcept V_CVT_I32_F64_e32 %0, implicit $exec, implicit $mode, implicit-def $m0

    S_ENDPGM 0, implicit %1
...

# CHECK-LABEL: repeat_rate_cmp_f64:
# CHECK: VALU(Nc): 32 cycles, 1 instrs

---
name: repeat_rate_cmp_f64
tracksRegLiveness: true
body: |
  bb.0:
    %0:vreg_64_align2 = IMPLICIT_DEF
    %1:sreg_32 = nofpexcept V_CMP_GT_F64_e64 0, %0, 0, %0, 0, implicit $mode, implicit $exec

    S_ENDPGM 0, implicit %1
...

# CHECK-LABEL: repeat_rate_arith_f64:
# CHECK: VALU(Nc): 32 cycles, 1 instrs

---
name: repeat_rate_arith_f64
tracksRegLiveness: true
body: |
  bb.0:
    %0:vreg_64_align2 = IMPLICIT_DEF
    %1:vreg_64_align2 = V_MIN_NUM_F64_e64 1, %0, 0, %0, 0, 0, implicit $mode, implicit $exec

    S_ENDPGM 0, implicit %1
...

# CHECK-LABEL: repeat_rate_shift_64:
# CHECK: VALU(Nc): 2 cycles, 1 instrs

---
name: repeat_rate_shift_64
tracksRegLiveness: true
body: |
  bb.0:
    %0:vreg_64_align2 = IMPLICIT_DEF
    %1:vreg_64_align2 = V_MOV_B64_e32 %0, implicit $exec

    S_ENDPGM 0, implicit %1
...

# CHECK-LABEL: repeat_rate_swap:
# CHECK: VALU(Nc): 2 cycles, 1 instrs

---
name: repeat_rate_swap
tracksRegLiveness: true
body: |
  bb.0:
    %0:vgpr_32 = IMPLICIT_DEF
    %1:vgpr_32, %2:vgpr_32 = V_PERMLANE32_SWAP_B32_e64 %0, %0, -1, 1, implicit $exec

    S_ENDPGM 0, implicit %1, implicit %2
...

# CHECK-LABEL: repeat_rate_int_mul:
# CHECK: VALU(Nc): 4 cycles, 1 instrs

---
name: repeat_rate_int_mul
tracksRegLiveness: true
body: |
  bb.0:
    %0:vgpr_32 = IMPLICIT_DEF
    %1:vgpr_32 = V_MUL_HI_U32_e64 1, %0:vgpr_32, implicit $exec

    S_ENDPGM 0, implicit %1
...
