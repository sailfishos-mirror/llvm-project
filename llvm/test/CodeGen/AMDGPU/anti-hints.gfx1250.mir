# Test: V_EXP_F32_e32 - with 1 VALU slots
name:            test_expf32
tracksRegLiveness: true
body:             |
  bb.0:
    liveins:

    ; CHECK-LABEL: name: test_expf32
    ; CHECK: renamable $vgpr0_vgpr1 = IMPLICIT_DEF
    ; CHECK-NEXT: renamable $vgpr2_vgpr3 = IMPLICIT_DEF
